"""}
        ],
        temperature=0.2,
        max_tokens=1000
    )
    return response.choices[0].message.content

def detect_changes(old_circular, new_circular):
    response = client.chat.completions.create(
        model="llama-3.3-70b-versatile",
        messages=[
            {"role": "system", "content": "You are a regulatory change detection expert for Indian companies."},
            {"role": "user", "content": f"""
Compare these two versions of a regulatory circular and detect EXACTLY what changed:

OLD VERSION:
{old_circular}

NEW VERSION:
{new_circular}

List every change clearly as:
✅ ADDED: [what was newly added]
❌ REMOVED: [what was removed]
🔄 MODIFIED: [what changed from X to Y]
⚠️ IMPACT: [why this change matters]
"""}
        ],
        temperature=0.3,
        max_tokens=1500
    )
    return response.choices[0].message.content
