def analyze_circular(circular_content, company_policy):
    response = client.chat.completions.create(
        model="llama-3.3-70b-versatile",
        messages=[
            {"role": "system", "content": "You are PolicyGuard, an expert AI compliance analyst for Indian companies."},
            {"role": "user", "content": f"""
Analyze this regulatory circular and generate a professional compliance impact report.

REGULATORY CIRCULAR:
{circular_content}

COMPANY CURRENT POLICY:
{company_policy}

Generate report with:
1. SUMMARY (2-3 lines of what changed)
2. IMPACT LEVEL (High/Medium/Low with reason)
3. AFFECTED AREAS in company policy
4. REQUIRED ACTIONS (numbered list)
5. DEADLINE (when to comply)
6. PENALTY IF IGNORED
7. RECOMMENDED POLICY AMENDMENTS
"""}
        ],
        temperature=0.3,
        max_tokens=2000
    )
    return response.choices[0].message.content

def generate_amendment(circular_content, policy_section):
    response = client.chat.completions.create(
        model="llama-3.3-70b-versatile",
        messages=[
            {"role": "system", "content": "You are a legal compliance expert for Indian companies."},
            {"role": "user", "content": f"""
Based on this regulatory circular:
{circular_content}

